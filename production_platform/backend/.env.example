# ─────────────────────────────────────────────────────────────────────────────
#  UniQuant — Backend .env  (DOCKER ONLY)
#
#  For local development you do NOT need this file.
#  The backend automatically walks up and finds UniQuant-main/.env instead.
#
#  You only need this file when running via Docker / docker-compose,
#  because the container is isolated and cannot see the project root.
#
#  Copy to .env and fill in your values:
#      cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=your-api-key-here
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
