# ─────────────────────────────────────────────────────────────────────────────
#  UniQuant — Single shared .env  (TEMPLATE)
#
#  This ONE file is read by all three servers during local development:
#    • Streamlit  — loaded via load_dotenv() in app.py
#    • FastAPI    — found automatically by find_dotenv() in config.py
#    • Next.js    — not needed (NEXT_PUBLIC_API_URL defaults to localhost:8000)
#
#  Copy to .env and fill in your values:
#      cp .env.example .env
#
#  For Docker, also copy production_platform/backend/.env.example → .env
# ─────────────────────────────────────────────────────────────────────────────

# Layer 4 — LLM Coherence Score (Claude Haiku)
# Get your key at: https://console.anthropic.com/
# Leave blank to skip Layer 4 — all other layers still work without it.
ANTHROPIC_API_KEY=your-api-key-here
